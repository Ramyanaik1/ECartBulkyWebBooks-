@model ECartBulkyWebBooks.Models.ViewModels.ProductVM

<form method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="Product.Id" />

    <div class="container mt-4">

        <h3>Create Product</h3>

        
        <div class="row mb-3">
            <div class="col-md-6">
                <label>Title</label>
                <div class="input-group">
                    <span class="input-group-text">📘</span>
                    <input asp-for="Product.Title" class="form-control" />
                </div>
            </div>

            <div class="col-md-6">
                <label>ISBN</label>
                <div class="input-group">
                    <span class="input-group-text">🔳</span>
                    <input asp-for="Product.ISBN" class="form-control" />
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
        </div>

        
        <div class="row mb-3">
            <div class="col-md-6">
                <label>Author</label>
                <div class="input-group">
                    <span class="input-group-text">👤</span>
                    <input asp-for="Product.Author" class="form-control" />
                </div>
            </div>

            <div class="col-md-6">
                <label>List Price</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Product.ListPrice" class="form-control" />
                </div>
            </div>
        </div>

        
        <div class="row mb-3">
            <div class="col-md-4">
                <label>Price for 1-50</label>
                <input asp-for="Product.Price" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Price for 50+</label>
                <input asp-for="Product.Price50" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Price for 100+</label>
                <input asp-for="Product.Price100" class="form-control" />
            </div>
        </div>

        
        <div class="mb-3">
            <label>Category Name</label>
            <select asp-for="Product.CategoryId"
                    asp-items="Model.CategoryList"
                    class="form-select">
                <option disabled selected>-- Select Category --</option>
            </select>
        </div>

        
        <div class="mb-3">
            <label>Upload Image</label>
            <input type="file" name="file" class="form-control" />
        </div>

        
        <div class="d-flex justify-content-between">
            <button type="submit" class="btn btn-success">
                CREATE
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                ← BACK TO LIST
            </a>
        </div>

    </div>

</form>