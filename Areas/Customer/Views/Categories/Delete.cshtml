@model ECartBulkyWebBooks.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<h2>Delete Category</h2>

<h4 class="text-danger">Are you sure you want to delete this category?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            Name
        </dt>
        <dd class="col-sm-10">
            @Model.Name
        </dd>

        <dt class="col-sm-2">
            Display Order
        </dt>
        <dd class="col-sm-10">
            @Model.DisplayOrder
        </dd>
    </dl>

    <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>